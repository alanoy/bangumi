    "@vercel/analytics": "^2.0.1",
    "daisyui": "^5.6.18",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-vue": "^9.33.0",
    "nuxt": "^4.4.8",
    "nuxt-security": "^2.6.0",
    "prettier": "^3.9.5",
